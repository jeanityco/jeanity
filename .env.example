# Jeanity — copy to `.env.local` for local development.
# On Vercel: Project → Settings → Environment Variables (enable Production + Preview).

# ── Required: URL + one public API key (anon OR publishable) ────────────────

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# If you use Supabase via Vercel Marketplace, you may get these instead of ANON_KEY:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...
# SUPABASE_PUBLISHABLE_KEY=...

# Non–NEXT_PUBLIC_ names are also accepted (next.config maps them for the client):
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=...

# ── Optional: local scripts only (never expose to the browser) ─────────────
# SUPABASE_SERVICE_ROLE_KEY=
